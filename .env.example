# Satellite GIS Extractor - Environment Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# Google Maps API (Required for drawing tool)
# ============================================
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Drawing Library
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# Google Earth Engine (Required for satellite data)
# ============================================
# Option 1: Service Account (Recommended for production)
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
EARTH_ENGINE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
EARTH_ENGINE_KEY_FILE=./config/earth-engine-key.json
EARTH_ENGINE_PROJECT_ID=your-gee-project-id

# Option 2: User Authentication (for development)
# Run 'earthengine authenticate' in terminal first
# Then leave above variables empty

# ============================================
# Server Configuration
# ============================================
PORT=5001
DEBUG=false
